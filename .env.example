# ===========================================
# AI SaaS Starter Kit - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# -------------------------------------------
# CLERK (Authentication)
# Get your keys at: https://dashboard.clerk.com/
# -------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# -------------------------------------------
# SUPABASE (Database)
# Get your keys at: https://supabase.com/dashboard
# -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# -------------------------------------------
# STRIPE (Payments)
# Get your keys at: https://dashboard.stripe.com/apikeys
# -------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Stripe Price IDs (create products in Stripe Dashboard)
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxxxx
STRIPE_PRO_YEARLY_PRICE_ID=price_xxxxx

# -------------------------------------------
# OPENAI (AI Integration)
# Get your key at: https://platform.openai.com/api-keys
# -------------------------------------------
OPENAI_API_KEY=sk-xxxxx

# -------------------------------------------
# ANTHROPIC / CLAUDE (AI Integration)
# Get your key at: https://console.anthropic.com/
# -------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxx

# -------------------------------------------
# REPLICATE (Image Generation)
# Get your key at: https://replicate.com/account/api-tokens
# -------------------------------------------
REPLICATE_API_TOKEN=r8_xxxxx

# -------------------------------------------
# RESEND (Email)
# Get your key at: https://resend.com/api-keys
# -------------------------------------------
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=noreply@yourdomain.com

# -------------------------------------------
# APP CONFIG
# -------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="AI SaaS Starter"
